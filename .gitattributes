# ====================================================================
# UNREAL ENGINE SPECIFIC
# ====================================================================
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text
*.upk filter=lfs diff=lfs merge=lfs -text
*.udk filter=lfs diff=lfs merge=lfs -text

# ====================================================================
# UNITY SPECIFIC
# ====================================================================
# Force text-based asset files to use Unity's smart merge tool (if configured)
*.cs text diff=csharp
*.meta text
*.unity text
*.prefab text
*.asset text
*.mat text
*.anim text
*.controller text
*.spriteatlas text

# Unity internal binaries that must use LFS (Do NOT track .meta files with LFS)
[Nn]av[Mm]esh.asset filter=lfs diff=lfs merge=lfs -text
*LightingData.asset filter=lfs diff=lfs merge=lfs -text

